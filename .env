# Connection URL for your Redis instance.
# Format:  redis://:<password>@<host>:<port>
# Upstash: rediss://:<password>@<host>:6379  (note: rediss:// for TLS)
REDIS_URL="redis://default:2zV2z6Svu2XODVhkb1eqcGdhJnm6r38p@redis-19174.crce218.eu-central-1-1.ec2.cloud.redislabs.com:19174"

# Bcrypt hash of the admin password.
# Generate: node -e "const b=require('bcryptjs'); console.log(b.hashSync('YOUR_PASSWORD', 12))"
ADMIN_PASSWORD_HASH=$2b$12$tbDtP6hLnV25fETSW5DNuu8zHRQVIBDOiDv760DAwm2brbi02vOk6

